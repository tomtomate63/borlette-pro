{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/agent-app/(.*)",
      "dest": "/agent-app/$1"
    },
    {
      "src": "/admin-app/(.*)",
      "dest": "/admin-app/$1"
    },
    {
      "src": "/caissier-app/(.*)",
      "dest": "/caissier-app/$1"
    },
    {
      "src": "/icon/(.*)",
      "dest": "/icon/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/",
      "dest": "/agent-app/index.html"
    }
  ]
}